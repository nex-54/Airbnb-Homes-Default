{
  "manifest_version": 3,
  "name": "Airbnb Homes Default",
  "description": "Opens the Homes tab by default on Airbnb instead of Experiences or Services",
  "version": "1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["webNavigation"],
  "host_permissions": ["*://*.airbnb.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.airbnb.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
